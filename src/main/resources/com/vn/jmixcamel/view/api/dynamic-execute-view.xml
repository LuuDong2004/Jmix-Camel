<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://dynamicExecuteView.title">
    <layout classNames="p-m" spacing="true" width="100%">

        <h3 text="Dynamic API Execution Engine"/>
        <span text="Send JSON config → call external API → extract fields → DB lookup → return enriched result"/>

        <hbox spacing="true">
            <button id="executeBtn" text="Execute" themeNames="primary"/>
            <button id="sampleBtn" text="Load Sample"/>
        </hbox>

        <textArea id="configArea"
                  label="Config (JSON)"
                  width="100%"
                  height="24em"
                  themeNames="small"/>

        <textArea id="resultArea"
                  label="Result"
                  width="100%"
                  height="24em"
                  readOnly="true"
                  themeNames="small"/>

    </layout>
</view>
